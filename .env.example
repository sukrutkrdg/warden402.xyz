# ── Bazaar (intelligence backend) ─────────────────────────────
# Warden, Bazaar'ı ZenginVeri katmanı olarak çağırır.
BAZAAR_BASE_URL=https://402.com.tr
# Internal-auth: bu secret ile Bazaar'ın x402 ödeme duvarı atlanır (kendi kendine fatura kesmemek için).
# Bazaar tarafında bu header'ı tanıyan bir bypass kurmalısın.
BAZAAR_INTERNAL_SECRET=change-me-shared-secret
# Bazaar çağrısı için zaman aşımı (ms). Aşılırsa sinyal 'unknown' → verdict degrade olur.
BAZAAR_TIMEOUT_MS=4000

# ── Claude (yalnızca düz-dil 'summary' için; karara dokunmaz) ──
ANTHROPIC_API_KEY=
WARDEN_SUMMARY_MODEL=claude-haiku-4-5-20251001
# Summary'yi kapatmak istersen (deterministik fallback metni kullanılır):
WARDEN_SUMMARY_ENABLED=true

# ── Karar eşikleri (kalibre edilebilir) ───────────────────────
WARDEN_BLOCK_THRESHOLD=70
WARDEN_REVIEW_THRESHOLD=35

# ── Sunucu ────────────────────────────────────────────────────
PORT=8787
