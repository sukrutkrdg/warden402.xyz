{
  "name": "warden402",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Warden — pre-execution security & trust layer for agents transacting on Base (warden402.xyz)",
  "workspaces": ["packages/*", "web"],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "smoke": "tsx scripts/smoke.ts"
  },
  "dependencies": {
    "@warden/core": "*",
    "@anthropic-ai/sdk": "^0.32.1",
    "@coinbase/x402": "^2.1.0",
    "@hono/node-server": "^1.13.7",
    "@x402/core": "^2.17.0",
    "@x402/evm": "^2.17.0",
    "@x402/hono": "^2.17.0",
    "hono": "^4.6.14",
    "ulid": "^2.3.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.9"
  }
}
