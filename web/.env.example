# Warden site, guard mantığını KENDİ İÇİNDE çalıştırır (ayrı API gerekmez).
# Bazaar'dan veriyi ÖDEMEDEN almak için internal-auth secret'ı gerekir:
BAZAAR_BASE_URL=https://402.com.tr
BAZAAR_INTERNAL_SECRET=          # Bazaar'daki WARDEN_INTERNAL_SECRET ile AYNI değer

# (Opsiyonel) Eşikler
# WARDEN_BLOCK_THRESHOLD=70
# WARDEN_REVIEW_THRESHOLD=35

# (Optional) If you have a separate API with a persistent ledger for track-record:
# WARDEN_API_URL=https://api.warden402.xyz

# ── Farcaster / Base App Mini App ─────────────────────────────
# Public origin (used in the manifest + embeds). Defaults to https://warden402.xyz
# NEXT_PUBLIC_SITE_URL=https://warden402.xyz
# Base App id (base.dev). A default is baked in; override only if you reuse this app.
# NEXT_PUBLIC_BASE_APP_ID=6a417fdf76506a652317fb64
# Domain-ownership proof for /.well-known/farcaster.json — generate ONCE for
# warden402.xyz with the Farcaster/Base manifest tool, then set all three:
# FARCASTER_HEADER=
# FARCASTER_PAYLOAD=
# FARCASTER_SIGNATURE=
